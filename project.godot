; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Mota"
run/main_scene="uid://b3stdisbq408"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="uid://bxw5pcooyj2k8"

[autoload]

FloorManager="*uid://cnh3hjjnc63h1"
EventBus="*uid://l1wxig1rn7i"

[display]

window/size/viewport_width=576
window/size/viewport_height=416
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/ai_assistant_hub/plugin.cfg", "res://addons/godot_xterm/plugin.cfg")

[gui]

theme/default_font_multichannel_signed_distance_field=true

