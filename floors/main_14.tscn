script = ExtResource("7_74xru")
speaker = 1
text = "老伯，请你看看这个"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_542m7"]
script = ExtResource("7_74xru")
text = "嗯...
这红宝石...这形状...
错不了了！是勇者之证！"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_shunh"]
script = ExtResource("7_74xru")
speaker = 1
text = "勇...勇者之证！？"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_ubeqx"]
script = ExtResource("7_74xru")
text = "没错！有了这个再配合增幅器，你的攻击次数就会上升，对于战斗十分有利的啊！"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

