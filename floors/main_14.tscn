[sub_resource type="Resource" id="Resource_8148f"]
script = ExtResource("7_74xru")
speaker = 1
text = "老伯，请你看看这个"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_ed3ec"]
script = ExtResource("7_74xru")
text = "嗯...
是一颗珍贵的钻石...
错不了了！是贤者之证！"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_rq588"]
script = ExtResource("7_74xru")
speaker = 1
text = "贤者之证！?"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_axaiu"]
script = ExtResource("7_74xru")
text = "对！有了它你就可以将对手的攻击力化成你的体力，虽然出现概率不高，但它还有一定概率会令你在战斗后回复少量体力"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_s1rjc"]
script = ExtResource("10_qujnt")
item = ExtResource("9_0tp4s")
metadata/_custom_type_script = "uid://ca3xixvnlvp5q"

