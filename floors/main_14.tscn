metadata/_custom_type_script = "uid://dgvxfb2vjrka"

[sub_resource type="Resource" id="Resource_wvcej"]
script = ExtResource("7_74xru")
text = "啊！！！！！！！
你的剑！！你的盾！！
全是古董呢！！！！！"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_52unh"]
script = ExtResource("7_74xru")
speaker = 1
text = "？
你懂鉴定的吗？"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_cih2b"]
script = ExtResource("7_74xru")
text = "这简单的东西怎会难倒我！"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_cvhj2"]
script = ExtResource("7_74xru")
speaker = 1
text = "啊！我有东西给你鉴定，你等我一下！"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_tplr4"]
script = ExtResource("7_74xru")
text = "随时欢迎"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_71hkq"]
script = ExtResource("7_74xru")
text = "怎样？不是有东西要鉴定吗？"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

