[sub_resource type="Resource" id="Resource_lso71"]
script = ExtResource("7_74xru")
speaker = 1
text = "老伯，请你看看这个"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_82hrc"]
script = ExtResource("7_74xru")
text = "噢！是黑珍珠！
不用看了！是霸者之证！"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_a6d2p"]
script = ExtResource("7_74xru")
speaker = 1
text = "霸者之证？那是什么？"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_ymsyt"]
script = ExtResource("7_74xru")
text = "你知道的真少嘛~ 只要拥有它，你就可以反弹对手的攻击使它也同时受伤，出现概率较高，要好好利用呢！"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

