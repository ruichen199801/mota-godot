[sub_resource type="Resource" id="Resource_n5u17"]
script = ExtResource("7_xhppm")
text = "稀客呢~是来救公主的吧？
但这层往后的怪物会变得更强
以你现在的实力
是绝对赢不了的！"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_jwfs7"]
script = ExtResource("7_xhppm")
speaker = 1
text = "是吗？
那怎么办？"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_2xuio"]
script = ExtResource("7_xhppm")
text = "嗯~~
我还是建议你到17F去取宝物
这个你拿去吧
拿到宝物后你的力量就会大增
到时再来找我~"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

