[sub_resource type="Resource" id="Resource_rlp4g"]
script = ExtResource("7_xhppm")
speaker = 1
text = "我拿到了！
力量真的增加了不少！
谢谢你！"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_qlms4"]
script = ExtResource("7_xhppm")
text = "不用谢~
等你救回了公主后再谢~
那么，加油吧！"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_t4bsd"]
script = ExtResource("7_xhppm")
text = "加油吧！
要是你救不了公主的话
我不会放过你的~"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

