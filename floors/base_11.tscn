[sub_resource type="Resource" id="Resource_harco"]
script = ExtResource("6_uhsgb")
text = "你发现与一些防御力超高的怪物战斗时，完全伤不了它们吗？这与攻击临界值有关，"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

[sub_resource type="Resource" id="Resource_c72c3"]
script = ExtResource("6_uhsgb")
text = "当它们的防御比你的攻击力高，而且高出的数值大于你的攻击临界值，你就伤不了它们，请留意"
metadata/_custom_type_script = "uid://nlow5r0mr3bq"

